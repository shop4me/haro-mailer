# Branding and public URLs (default: Floatfire)
APP_DOMAIN=floatfire.com
PUBLIC_BASE_URL=https://floatfire.com
APP_NAME=Floatfire HARO

OPENAI_API_KEY=
ADMIN_PASSWORD=change-me
FLASK_SECRET_KEY=change-me-too
# Create Postgres user and DB first — see README.
DATABASE_URL=postgresql://haro:haro@127.0.0.1:5432/haro
GLOBAL_AUTO_SEND=false
GLOBAL_DRY_RUN=true
GLOBAL_REVIEW_MODE=true
MAX_SENDS_PER_RUN=20
LOOKBACK_HOURS=48
# Poll every N minutes when using scheduler (default 10). Set 0 to use RUN_TIMES instead.
POLL_INTERVAL_MINUTES=10
RUN_TIMES=08:00,13:00,18:00

# Asset pipeline (optional; conservative defaults in example — production may enable all)
ENABLE_ASSET_AUTOMATION=false
ENABLE_AI_CONCEPT_VISUALS=false
ENABLE_INLINE_IMAGE_PREVIEWS=false
MAX_INLINE_PREVIEW_IMAGES=2
MAX_GENERATED_CANDIDATES=6
AUTO_SEND_CONCEPT_VISUALS=false
AUTO_SEND_REAL_ASSETS=false
ASSET_PLANNER_USE_LLM=false

# Optional: BCC every sent reply to this address (same content + attachments as the journalist sees)
# REPLY_BCC_EMAIL=you@example.com

# Optional: comma-separated dirs of real lifestyle images; editorial library path
# BUSINESS_LIFESTYLE_IMAGE_DIRS=/path/to/images
# EDITORIAL_ASSET_LIBRARY_DIR=/path/to/editorial
